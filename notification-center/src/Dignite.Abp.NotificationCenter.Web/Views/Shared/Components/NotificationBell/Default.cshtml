@using Microsoft.Extensions.Localization
@using Microsoft.Extensions.Options
@using Dignite.Abp.NotificationCenter.Localization
@using Dignite.Abp.NotificationCenter.Web.Components.NotificationBell
@model NotificationBellViewModel
@inject IOptions<NotificationCenterWebOptions> WebOptionsAccessor
@inject IStringLocalizer<NotificationCenterResource> L
@{
    var options = WebOptionsAccessor.Value;
}
<div class="dignite-notification-bell dropdown" data-signalr-hub-url="@Model.SignalRHubUrl">
    <button class="btn btn-link position-relative p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="fa fa-bell"></i>
        <span class="dignite-notification-badge badge bg-danger rounded-pill position-absolute top-0 start-100 translate-middle"
              data-count="@Model.UnreadCount" @(Model.UnreadCount > 0 ? "" : "hidden")>@Model.UnreadCount</span>
    </button>
    <div class="dropdown-menu dropdown-menu-end dignite-notification-list p-0">
        <div class="d-flex justify-content-between align-items-center p-2 border-bottom">
            <strong>@L["Notifications"]</strong>
            <a href="#" class="dignite-notification-mark-all-read small">@L["MarkAllAsRead"]</a>
        </div>
        @if (!Model.Items.Any())
        {
            <div class="p-3 text-muted">@L["NoNotifications"]</div>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <a href="@(item.Url ?? "#")"
                   class="dignite-notification-item d-block p-2 border-bottom text-decoration-none text-body @(item.Notification.State == UserNotificationState.Unread ? "dignite-notification-unread" : "")"
                   data-notification-id="@item.Notification.NotificationId"
                   data-has-link="@(item.Url != null ? "true" : "false")">
                    <div class="d-flex justify-content-between">
                        <small class="@item.Notification.Severity.ToTextColorCssClass()">
                            @(string.IsNullOrEmpty(item.Notification.NotificationDisplayName) ? item.Notification.NotificationName : item.Notification.NotificationDisplayName)
                        </small>
                        <small class="text-muted">@item.Notification.CreationTime.ToString("g")</small>
                    </div>
                    @if (item.Discriminator != null && options.DataViewComponents.TryGetValue(item.Discriminator, out var dataViewComponentType))
                    {
                        @await Component.InvokeAsync(dataViewComponentType, new { data = item.Notification.Data })
                    }
                    else if (item.Notification.Data is IHasNotificationImageUrl { ImageUrl.Length: > 0 } withImage)
                    {
                        <img src="@withImage.ImageUrl" class="dignite-notification-image" alt="" />
                    }
                </a>
            }
        }
    </div>
</div>
